# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Go workspace file
go.work

# Build output directories
bin/

# goreleaser local-run artifacts. `goreleaser release --snapshot` writes
# everything (archives, checksums, SBOMs, cosign bundles) under dist/.
# Ignoring it lets us run goreleaser locally to verify config without
# dirtying the working tree.
dist/

# Cosign signature bundles and CycloneDX SBOMs — released artifacts only;
# they should never live in the source tree. Defensive pattern in case
# someone curls a release asset down for verification testing.
*.sigstore.json
*.sbom.cdx.json

# Dependency directories (remove the comment below to include it)
# vendor/

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local

# Local-only agent notes and tooling (not part of the public repo)
AGENTS.md
CLAUDE.md
.claude/
